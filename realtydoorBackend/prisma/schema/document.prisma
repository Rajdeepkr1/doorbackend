// ─── USER DOCUMENT VAULT ──────────────────────────────────────────────────────
// Stores KYC and loan documents uploaded by buyers (PRD Pattern 12).
// Admin reviews and marks isVerified; Partner (lender) can view approved docs.

model UserDocument {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @db.ObjectId
  user         User      @relation(fields: [userId], references: [id])

  // documentType: PAN_CARD | AADHAR | SALARY_SLIP | FORM_16 | BANK_STATEMENT
  documentType String
  fileUrl      String
  fileName     String
  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?
  uploadedAt   DateTime  @default(now())

  @@index([userId])
}

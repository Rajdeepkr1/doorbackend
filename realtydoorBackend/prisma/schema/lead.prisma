// ─── LEAD ─────────────────────────────────────────────────────────────────────
// Central unit of the anti-leakage engine (PRD §5).
// buyerPhone is stored plain; masking is computed at the API layer via formatPhone().
// siteVisitOTP is cleared from DB after successful verification.

model Lead {
  id               String     @id @default(auto()) @map("_id") @db.ObjectId
  buyerName        String
  buyerEmail       String
  buyerPhone       String
  buyerId          String?    @db.ObjectId
  buyerMessage     String?
  propertyId       String     @db.ObjectId
  property         Property   @relation(fields: [propertyId], references: [id])
  status           LeadStatus @default(UNASSIGNED)
  assignedPartnerId String?   @db.ObjectId
  assignedPartner  User?      @relation("PartnerLeads", fields: [assignedPartnerId], references: [id])
  assignedAt       DateTime?
  adminNotes       String?

  // OTP anti-leakage (PRD §5 — Rules 1, 2, 3)
  siteVisitScheduledAt DateTime?
  siteVisitOTP         String?    // cleared after verification
  otpGeneratedAt       DateTime?
  otpExpiresAt         DateTime?  // = otpGeneratedAt + OTP_EXPIRY_MINUTES
  otpAttempts          Int        @default(0)
  otpLockedUntil       DateTime?  // set after OTP_MAX_ATTEMPTS failures
  isOtpVerified        Boolean    @default(false)
  otpVerifiedAt        DateTime?

  // WhatsApp buyer feedback cross-check (PRD §5 — Leakage 1)
  whatsappSentAt      DateTime?
  buyerFeedbackStatus String?
  feedbackReceivedAt  DateTime?

  // Partner documentation
  visitNotes          String?
  visitPhotoUrls      String[]
  closureDocumentUrls String[]
  partnerNotes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  escrowTransactions EscrowTransaction[]

  @@index([assignedPartnerId])
  @@index([buyerId])
  @@index([status])
  @@index([propertyId])
}
